        <mxCell id="aHLzR4RYqQtunB-r-0Pg-1134" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="Elasticsearch is a &lt;b data-index-in-node=&quot;19&quot; data-path-to-node=&quot;5&quot;&gt;Search Engine&lt;/b&gt;&lt;span class=&quot;citation-12 citation-end-12&quot;&gt;, not a traditional database.&lt;sup data-turn-source-index=&quot;2&quot; class=&quot;superscript&quot;&gt;&lt;/sup&gt;&lt;/span&gt; &lt;br&gt;&lt;span class=&quot;citation-11&quot;&gt;It is built on top of a library called &lt;/span&gt;&lt;b data-index-in-node=&quot;101&quot; data-path-to-node=&quot;5&quot;&gt;Apache Lucene&lt;/b&gt;&lt;span class=&quot;citation-11 citation-end-11&quot;&gt;.&lt;sup data-turn-source-index=&quot;3&quot; class=&quot;superscript&quot;&gt;&lt;/sup&gt;&lt;/span&gt;" vertex="1">
